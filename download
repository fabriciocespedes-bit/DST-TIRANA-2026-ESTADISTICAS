function _ht(c,mx,my){let best=null,bd=1e9;for(const h of c.hits){if(h.rect){const[x,y,w,hh]=h.rect;if(mx>=x&&mx<=x+w&&my>=y&&my<=y+hh)return h;}else if(h.px!=null){const d=Math.abs(mx-h.px);if(d<bd){bd=d;best=h;}}}return (best&&bd<44)?best:null;}
